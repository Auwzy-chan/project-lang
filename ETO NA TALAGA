    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.5px;
}

.section-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 6px;
    margin-bottom: 28px;
}

.view-all-link {
    background: transparent;
    border: none;
    color: var(--accent-orange);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
}

.view-all-link:hover {
    text-decoration: underline;
}

/* Premium Automotive Inventory Product Cards grid systems infrastructure */
.car-grid {
    display: grid;
    gap: 24px;
}

.car-grid.columns-4 {
    grid-template-columns: repeat(4, 1fr);
}

.car-card {
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease;
}

.car-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-focus);
}

.card-image-wrapper {
    position: relative;
    height: 160px;
    background-color: #000;
}

.card-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
}

.card-image-wrapper .badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
}

.rating-tag {
    position: absolute;
    bottom: 12px;
    right: 14px;
    background-color: rgba(7, 11, 18, 0.75);
    backdrop-filter: blur(4px);
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--clr-yellow);
}

.card-details {
    padding: 20px;
}

.card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 6px;
}

.card-title-row h3 {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
}

.car-year {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.2);
}

.car-specs {
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.card-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 16px 0;
}

.card-divider.light {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.card-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.price-main {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--accent-orange);
}

.price-sub {
    font-size: 0.72rem;
    color: var(--text-secondary);
    margin-top: 2px;
}

.action-circle-btn {
    width: 32px;
    height: 32px;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-subtle);
    color: var(--accent-orange);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
}

.car-card:hover .action-circle-btn {
    background-color: var(--accent-orange);
    color: #000000;
    border-color: var(--accent-orange);
}

/* Dynamic promotional banner display footer card structure layout blueprint block */
.promo-callout-box {
    background: linear-gradient(rgba(15, 20, 32, 0.9), rgba(15, 20, 32, 0.9)),
                url('https://images.unsplash.com/photo-1555215695-3004980ad54e?auto=format&fit=crop&q=80&w=1000') no-repeat center center;
    background-size: cover;
    border: 1.5px solid rgba(255, 153, 0, 0.2);
    border-radius: 14px;
    padding: 32px 40px;
    margin-top: 56px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
}

.callout-text-side h3 {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
}

.callout-text-side p {
    font-size: 0.85rem;
    color: var(--text-secondary);
}


/* 2. INVENTORY FILTER MECHANICS OVERRIDES */
.inventory-top-bar {
    margin-bottom: 32px;
}

.inventory-top-bar .section-subtitle {
    margin-bottom: 0;
}

.filter-controls-row {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
}

.search-input-wrapper {
    flex: 1;
    position: relative;
}

.search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.search-input-wrapper input {
    width: 100%;
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    border-radius: 10px;
    padding: 14px 16px 14px 44px;
    color: var(--text-primary);
    font-size: 0.9rem;
    outline: none;
}

.custom-dropdown-select {
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    color: var(--text-primary);
    border-radius: 10px;
    padding: 0 20px;
    font-size: 0.85rem;
    font-weight: 600;
    outline: none;
    cursor: pointer;
    min-width: 160px;
}

.pill-filters-row {
    display: flex;
    gap: 10px;
    margin-bottom: 32px;
}

.pill {
    background-color: var(--bg-card-panel);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    padding: 8px 18px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
}

.pill:hover {
    color: var(--text-primary);
    border-color: var(--border-focus);
}

.pill.active {
    background-color: var(--accent-orange);
    color: #000000;
    border-color: var(--accent-orange);
}


/* 3. FINANCE CALCULATOR SCHEMATICS LAYOUT BLOCKS */
.calculator-layout-split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 32px;
    margin-top: 40px;
    align-items: start;
}

.calc-controls-card {
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    border-radius: 14px;
    padding: 32px;
}

.slider-control-group {
    margin-bottom: 32px;
}

.slider-label-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 14px;
}

.slider-output-val {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.1rem;
}

.custom-slider {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 2px;
    background: var(--border-subtle);
    outline: none;
}

/* Range Slider thumb styling configurations handles */
.custom-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent-orange);
    cursor: pointer;
    transition: transform 0.1s ease;
}
.custom-slider::-webkit-slider-thumb:hover { transform: scale(1.2); }

.slider-bounds {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.15);
    margin-top: 8px;
    font-weight: 500;
}

.term-selector-group label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 12px;
}

.term-buttons-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
}

.term-btn {
    background-color: var(--bg-input-field);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    padding: 12px 0;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
}

.term-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-focus);
}

.term-btn.active {
    background-color: var(--accent-orange);
    color: #000000;
    border-color: var(--accent-orange);
}

/* Right side Output configuration metrics report statement card box panel styling */
.calc-summary-card {
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    border-radius: 14px;
    padding: 32px;
}

.summary-card-header {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 0.5px;
}

.monthly-payment-display {
    margin: 24px 0 32px 0;
}

.monthly-payment-display .primary-amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--accent-orange);
    line-height: 1;
}

.monthly-payment-display .sub-lbl {
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin-top: 6px;
    font-weight: 500;
}

.summary-line-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    margin-bottom: 14px;
    color: var(--text-secondary);
}

.summary-line-item span:last-child {
    color: var(--text-primary);
    font-weight: 600;
}

.green-text { color: var(--clr-teal) !important; }
.orange-text { color: var(--accent-orange) !important; }

.summary-line-item.final-total {
    margin-top: 16px;
    font-size: 0.95rem;
    font-weight: 700;
}

.summary-line-item.final-total span:first-child {
    color: var(--text-primary);
}

.calc-legal-disclaimer {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.15);
    line-height: 1.4;
    margin-top: 24px;
}


/* 4. DISCOUNTS & AVAILABLE OFFERS DISPLAY GRID PANELS SCENARIO */
.offers-grid-layout {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
}

.offer-card-item {
    background-color: var(--bg-card-panel);
    border: 1.5px solid var(--border-subtle);
    border-radius: 14px;
    padding: 32px;
    position: relative;
    overflow: hidden;
}

.offer-card-body {
    position: relative;
    z-index: 5;
}

.offer-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
}

.offer-card-body h3 {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 10px;
}

.offer-card-body p {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 24px;
    max-width: 85%;
}

.coupon-action-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.coupon-code-container {
    background-color: var(--bg-input-field);
    border: 1px dashed var(--border-focus);
    border-radius: 8px;
    padding: 8px 14px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
}

.coupon-code-container span {
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.5px;
}

.copy-embed-btn {
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.85rem;
}

.copy-embed-btn:hover { color: var(--text-primary); }

.expiry-stamp {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.15);
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

/* Background watermark typography decorations element layout overlay */
.watermark-percentage {
    position: absolute;
    right: -10px;
    top: 0px;
    font-size: 7.5rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.02);
    user-select: none;
    line-height: 1;
    z-index: 1;
}

.info-guide-card {
    background-color: rgba(0, 180, 216, 0.03);
    border: 1.5px solid rgba(0, 180, 216, 0.15);
    border-radius: 12px;
    padding: 24px;
    margin-top: 32px;
}

.guide-header-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}

.icon-blue { color: var(--clr-blue); font-size: 1rem; }

.info-guide-card h4 {
    font-size: 0.9rem;
    font-weight: 700;
}

.info-guide-card p {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
}


/* 5. LEGAL TERMS ACCORDION LIST VIEWS */
.accordion-list-stack {
    display: flex;
    flex-direction: column;
    gap: 18px;
    margin-top: 40px;
    max-width: 900px;
    width: 100%;
}

.accordion-node {
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
}

.accordion-node:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.16);
}

.accordion-trigger {
    padding: 20px 26px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
    transition: background-color 0.25s ease;
    background-color: transparent;
}

.accordion-node.open .accordion-trigger {
    background-color: rgba(255, 255, 255, 0.06);
}

.accordion-trigger:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

.accordion-trigger span {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
}

.accordion-trigger i {
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: transform 0.25s ease;
}

.accordion-node.open .accordion-trigger i {
    transform: rotate(180deg);
    color: var(--accent-orange);
}

.accordion-panel-content {
    max-height: 0;
    overflow: hidden;
    padding: 0 24px;
    transition: max-height 0.35s ease, padding 0.35s ease;
}

.accordion-panel-content p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0;
    padding-top: 18px;
}

.accordion-node.open .accordion-panel-content {
    max-height: 380px;
    padding: 18px 24px 24px 24px;
}

.accordion-node.open {
    border-color: var(--accent-orange);
    background-color: rgba(255, 153, 0, 0.06);
}


/* ==========================================================================
   GLOBAL APP LEVEL WIDGET FLOATING COMPONENTS
   ========================================================================== */
.floating-help-trigger-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    cursor: pointer;
    z-index: 2000;
    transition: all 0.2s ease;
}

.floating-help-trigger-widget:hover {
    color: var(--text-primary);
    border-color: var(--border-focus);
    background-color: var(--bg-card-panel);
}
