        // FINANCING CALCULATOR FUNCTIONALITY
        function formatCurrency(value) {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'PHP',
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            }).format(value);
        }

        function calculatePayment() {
            const priceSlider = document.querySelector('#tab-finance .slider-control-group:nth-child(1) input[type="range"]');
            const downPaymentSlider = document.querySelector('#tab-finance .slider-control-group:nth-child(2) input[type="range"]');
            const rateSlider = document.querySelector('#tab-finance .slider-control-group:nth-child(3) input[type="range"]');
            
            const vehiclePrice = parseFloat(priceSlider.value);
            const downPayment = parseFloat(downPaymentSlider.value);
            const aprRate = parseFloat(rateSlider.value) / 10;
            
            const termBtn = document.querySelector('#tab-finance .term-btn.active');
            const termMonths = parseInt(termBtn.textContent);
            
            const loanAmount = vehiclePrice - downPayment;
            const monthlyRate = aprRate / 100 / 12;
            let monthlyPayment = 0;
            
            if (monthlyRate === 0) {
                monthlyPayment = loanAmount / termMonths;
            } else {
                monthlyPayment = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, termMonths)) / (Math.pow(1 + monthlyRate, termMonths) - 1);
            }
            
            const totalPayment = monthlyPayment * termMonths;
            const totalInterest = totalPayment - loanAmount;
            const totalCost = vehiclePrice + totalInterest;
            
            const priceOutput = document.querySelector('#tab-finance .slider-control-group:nth-child(1) .slider-output-val');
            const downPaymentOutput = document.querySelector('#tab-finance .slider-control-group:nth-child(2) .slider-output-val');
            const rateOutput = document.querySelector('#tab-finance .slider-control-group:nth-child(3) .slider-output-val');
            
            priceOutput.textContent = formatCurrency(vehiclePrice);
            downPaymentOutput.textContent = formatCurrency(downPayment);
            rateOutput.textContent = aprRate.toFixed(1) + '%';
            downPaymentSlider.max = vehiclePrice;
            
            const primaryAmount = document.querySelector('#tab-finance .primary-amount');
            const subLabel = document.querySelector('#tab-finance .sub-lbl');
            const summaryItems = document.querySelectorAll('#tab-finance .summary-line-item');
            const finalTotal = document.querySelector('#tab-finance .final-total span:last-child');
            
            primaryAmount.textContent = formatCurrency(monthlyPayment);
            subLabel.textContent = `per month for ${termMonths} months`;
            
            summaryItems[0].querySelector('span:last-child').textContent = formatCurrency(vehiclePrice);
            summaryItems[1].querySelector('span:last-child').textContent = formatCurrency(downPayment);
            summaryItems[2].querySelector('span:last-child').textContent = formatCurrency(loanAmount);
            summaryItems[3].querySelector('span:last-child').textContent = formatCurrency(totalInterest);
            
            finalTotal.textContent = formatCurrency(totalCost);
        }

        function initFinancingCalculator() {
            const tab = document.getElementById('tab-finance');
            if (!tab) return;
            
            const sliders = tab.querySelectorAll('input[type="range"]');
            sliders.forEach(slider => {
                slider.addEventListener('input', calculatePayment);
            });
            
            const termBtns = tab.querySelectorAll('.term-btn');
            termBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    termBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    calculatePayment();
                });
            });
            
            calculatePayment();
        }

