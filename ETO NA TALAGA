                const name = (card.dataset.name || '').toLowerCase();
                const keywords = (card.dataset.keywords || '').toLowerCase();
                const category = (card.dataset.category || '').toLowerCase();
                const price = card.dataset.price || '';
                const matchesSearch = !searchTerm || name.includes(searchTerm) || keywords.includes(searchTerm);
                const matchesCategory = selectedCategory === 'all' || category === selectedCategory;
                const shouldShow = matchesSearch && matchesCategory;
                card.style.display = shouldShow ? '' : 'none';
                return shouldShow;
            });

            const sortedCards = visibleCards.slice();
            if (sortOption === 'Price: Low to High') {
                sortedCards.sort((a, b) => parseInt(a.dataset.price, 10) - parseInt(b.dataset.price, 10));
            } else if (sortOption === 'Price: High to Low') {
                sortedCards.sort((a, b) => parseInt(b.dataset.price, 10) - parseInt(a.dataset.price, 10));
            } else {
                sortedCards.sort((a, b) => parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating));
            }

            sortedCards.forEach(card => {
                if (grid && card.parentElement === grid) {
                    grid.appendChild(card);
                }
            });

            updateInventoryCount(visibleCards.length);
        }

        function initInventoryFilters() {
            const searchInput = document.getElementById('inventory-search');
            const sortSelect = document.getElementById('inventory-sort');
            const pillButtons = document.querySelectorAll('#tab-inventory .pill-filters-row .pill');

            if (searchInput) {
                searchInput.addEventListener('input', applyInventoryFilters);
            }

            if (sortSelect) {
                sortSelect.addEventListener('change', applyInventoryFilters);
            }

            pillButtons.forEach(button => {
                button.addEventListener('click', () => {
                    pillButtons.forEach(btn => btn.classList.remove('active'));
                    button.classList.add('active');
                    applyInventoryFilters();
                });
            });

            applyInventoryFilters();
        }

        function initOfferCopyActions() {
            const copyButtons = document.querySelectorAll('#tab-offers .copy-embed-btn');
            copyButtons.forEach(button => {
                button.addEventListener('click', (e) => {
                    e.preventDefault();
                    const codeContainer = button.closest('.coupon-code-container');
                    const codeSpan = codeContainer ? codeContainer.querySelector('span') : null;
                    const couponCode = codeSpan ? codeSpan.textContent.trim() : '';
                    if (!couponCode) return;

                    const showCopiedState = () => {
                        button.innerHTML = '<i class="fa-solid fa-check"></i> Copied';
                        button.classList.add('copied');
                        window.setTimeout(() => {
                            button.innerHTML = '<i class="fa-regular fa-copy"></i>';
                            button.classList.remove('copied');
                        }, 1400);
                    };

                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(couponCode).then(showCopiedState).catch(() => {
                            showCopiedState();
                        });
                    } else {
                        const textarea = document.createElement('textarea');
                        textarea.value = couponCode;
                        textarea.style.position = 'fixed';
                        textarea.style.left = '-9999px';
                        document.body.appendChild(textarea);
                        textarea.select();
                        document.execCommand('copy');
                        document.body.removeChild(textarea);
                        showCopiedState();
                    }
                });
            });
        }

        // Initialize everything when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                initFinancingCalculator();
                initCarCardHandlers();
                initInventoryFilters();
                initOfferCopyActions();
            });
        } else {
            initFinancingCalculator();
            initCarCardHandlers();
            initInventoryFilters();
            initOfferCopyActions();
        }
    </script>
</body>
</html>





