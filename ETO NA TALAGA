<body>

    <div id="auth-container" class="auth-wrapper">
        <div class="auth-banner">
            <div class="brand-header">
                <div class="brand-icon"><i class="fa-solid fa-car-side"></i></div>
                <span class="brand-name">AUTO HUB</span>
            </div>
            <div class="banner-content">
                <span class="sub-tag">PREMIER DEALERSHIP</span>
                <h1>YOUR NEXT<br><span class="highlight">DREAM CAR</span><br>AWAITS.</h1>
                <p>Browse, finance, and book your next premium vehicle — all in one place.</p>
                
                <div class="banner-stats">
                    <div class="stat-item">
                        <h3>500+</h3>
                        <p>Vehicles</p>
                    </div>
                    <div class="stat-item">
                        <h3>4.9★</h3>
                        <p>Rating</p>
                    </div>
                    <div class="stat-item">
                        <h3>15yr</h3>
                        <p>Experience</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="view-signin" class="auth-form-side active-view">
            <div class="form-container">
                <div class="auth-toggle-header">
                    <button class="toggle-btn active">Sign In</button>
                    <button class="toggle-btn" onclick="switchView('view-signup')">Create Account</button>
                </div>
                
                <h2>WELCOME BACK</h2>
                <p class="form-subtitle">Sign in to your account to continue</p>

                <form onsubmit="handleSigninSubmit(event);">
                    <div class="input-group">
                        <label>Email Address</label>
                        <input type="email" name="email" placeholder="you@example.com" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="••••••••" required>
                    </div>
                    <button type="submit" class="btn-primary main-submit">Sign In</button>
                </form>
                <p class="demo-notice">Demo: any email + 6+ character password</p>
            </div>
        </div>

        <div id="view-signup" class="auth-form-side">
            <div class="form-container">
                <div class="auth-toggle-header">
                    <button class="toggle-btn" onclick="switchView('view-signin')">Sign In</button>
                    <button class="toggle-btn active">Create Account</button>
                </div>
                
                <h2>JOIN AUTO HUB</h2>
                <p class="form-subtitle">Create your account to get started</p>

                <form onsubmit="handleSignupSubmit(event);">
                    <div class="input-group">
                        <label>Full Name</label>
                        <input type="text" name="Full_Name" placeholder="Alex Rivera" required>
                    </div>
                    <div class="input-group">
                        <label>Email Address</label>
                        <input type="email" name="Email_Address" placeholder="you@example.com" required>
                    </div>
                    <div class="input-group">
                        <label>Phone Number</label>
                        <input type="tel" name="Phone_Number" placeholder="+63 9XX XXX XXXX" required>
                    </div>
                    <div class="input-group">
                        <label>Password</label>
                        <input type="password" name="Password" placeholder="••••••••" required>
                    </div>
                    <button type="submit" class="btn-primary main-submit">Create Account</button>
                </form>
            </div>
        </div>
    </div>


