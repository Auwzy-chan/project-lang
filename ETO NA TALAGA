    <style>
        /* Stats Grid Styling from Auto Dealer Hub.json */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            border-top: 1px solid rgba(31, 41, 55, 0.6);
            padding-top: 1.5rem;
